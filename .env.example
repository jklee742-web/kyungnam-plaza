# YouTube OAuth 2.0 credentials file (download from Google Cloud Console)
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json

# Token file path (auto-generated after first OAuth login)
YOUTUBE_TOKEN_FILE=token.json

# Anthropic API key (optional, for AI-assisted features)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Download settings
DOWNLOAD_DIR=downloads
VIDEO_FORMAT=best[ext=mp4]/best
